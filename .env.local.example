ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Get a key at https://aistudio.google.com/apikey — enables real cone analysis (otherwise mock data is used)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: GEMINI_MODEL=gemini-2.0-flash
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Supabase (required for database)
SUPABASE_URL=https://your-project-ref.supabase.co
# Use either the anon key (with RLS enabled) or the service_role key:
SUPABASE_ANON_KEY=your_anon_publishable_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
